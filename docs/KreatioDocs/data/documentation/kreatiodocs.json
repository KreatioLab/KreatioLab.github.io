KreatioDocs\/Nuestros-mentores","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestra_consultora","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Redes_Sociales"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kreatiodocs"]}],"primaryContentSections":[{"content":[{"text":"KreatioLab - La Academia de Datos que revoluciona la enseñanza y la industria","type":"heading","anchor":"KreatioLab-La-Academia-de-Datos-que-revoluciona-la-ense%C3%B1anza-y-la-industria","level":2},{"inlineContent":[{"type":"text","text":"En la encrucijada de la educación y la innovación tecnológica, "},{"inlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}],"type":"strong"},{"text":" emerge como un faro de cambio radical. Con sedes repartidas entre Europa y Latinoamérica, esta institución no solo se propone transformar cómo se enseña, sino también cómo se construyen los proyectos de datos en la industria actual.","type":"text"}],"type":"paragraph"},{"identifier":"Intro.mp4","type":"video"},{"text":"Una misión de cambio e inspiración","type":"heading","anchor":"Una-misi%C3%B3n-de-cambio-e-inspiraci%C3%B3n","level":2},{"inlineContent":[{"text":"El mundo de hoy enfrenta un ciclo vicioso en el que la enseñanza sin inspiración y alejada del ámbito laboral lleva a trabajos monótonos y a una innovación estancada. KreatioLab nace como respuesta a esta problemática, con la convicción de que cambiar la forma de enseñar es el primer paso para revolucionar la industria y la investigación. La academia se posiciona en la vanguardia, dispuesta a cortar las lianas de un sistema obsoleto, guiando a estudiantes y profesionales hacia una era de proyectos innovadores y emprendimientos revolucionarios.","type":"text"}],"type":"paragraph"},{"text":"Tutoriales interactivos, módulos de especialización y rutas de aprendizaje.","type":"heading","anchor":"Tutoriales-interactivos-m%C3%B3dulos-de-especializaci%C3%B3n-y-rutas-de-aprendizaje","level":2},{"inlineContent":[{"type":"text","text":"KreatioLab ofrece una variedad de "},{"type":"strong","inlineContent":[{"type":"text","text":"tutoriales interactivos"}]},{"type":"text","text":", "},{"type":"strong","inlineContent":[{"text":"módulos de especialización","type":"text"}]},{"type":"text","text":" y "},{"type":"strong","inlineContent":[{"type":"text","text":"rutas de aprendizaje"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"recomendadas"}]},{"type":"text","text":", destinados a formar a los líderes del mañana en el ámbito de los datos, en particular en estas áreas:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"✅ "},{"inlineContent":[{"text":"Data Analytics & Business Intelligence","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"✅ ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Data Science: Machine Learning & Deep Learning"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"✅ "},{"inlineContent":[{"text":"Data Engineering con AWS","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"type":"text","text":"Artificial Intelligence & Advanced Deep Learning"}]}],"type":"paragraph"},{"text":"Metodología y ventajas competitivas","type":"heading","anchor":"Metodolog%C3%ADa-y-ventajas-competitivas","level":2},{"inlineContent":[{"type":"text","text":"En "},{"type":"strong","inlineContent":[{"type":"text","text":"KreatioLab"}]},{"type":"text","text":", la formación es impartida por "},{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestros-mentores","type":"reference","isActive":true},{"type":"text","text":" que poseen años de "},{"type":"strong","inlineContent":[{"text":"experiencia práctica","type":"text"}]},{"type":"text","text":" en el ámbito de los datos, muchos de los cuales han liderado equipos y áreas completas dentro de empresas reconocidas."}],"type":"paragraph"},{"text":"Historias de éxito y testimonios","type":"heading","anchor":"Historias-de-%C3%A9xito-y-testimonios","level":2},{"inlineContent":[{"text":"A lo largo de los años, KreatioLab ha visto cómo sus alumnos se transforman en profesionales inspirados y motivados. Las historias de éxito adornan la academia, con ","type":"text"},{"identifier":"https:\/\/kreatiolab.com\/#testimoniales","type":"reference","isActive":true},{"text":" de estudiantes que ahora trabajan en diversas posiciones en el área del dato, participan y lideran proyectos y contribuyen a la innovación en múltiples sectores.","type":"text"}],"type":"paragraph"},{"text":"Cómo unirse a KreatioLab","type":"heading","anchor":"C%C3%B3mo-unirse-a-KreatioLab","level":2},{"inlineContent":[{"type":"text","text":"El proceso de inscripción en KreatioLab es muy simple: únete a nuestra comunidad haciendo esta plataforma tuya "},{"inlineContent":[{"type":"text","text":"sin costo alguno"}],"type":"strong"},{"type":"text","text":". "},{"inlineContent":[{"type":"text","text":"Comienza a explorar los contenidos que hemos desarrollado para ti de forma gratuita,"}],"type":"strong"},{"type":"text","text":" comprenderás el complejo mundo del dato, para luego de construir bases sólidas, elegir tutoriales interactivos, módulos de especialización y junto a un mentor y "},{"inlineContent":[{"text":"recibir orientación sobre cómo iniciar","type":"text"}],"type":"strong"},{"type":"text","text":" una "},{"inlineContent":[{"type":"text","text":"ruta de aprendizaje"}],"type":"strong"},{"type":"text","text":" y un plan de carrera."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KreatioLab no es solo una academia; es un movimiento. Con cada clase, cada módulo de especialización y cada carrera, está "},{"type":"strong","inlineContent":[{"type":"text","text":"redefiniendo"}]},{"type":"text","text":" lo que significa aprender y aplicar el conocimiento en el mundo real. "},{"type":"strong","inlineContent":[{"type":"text","text":"Únete a KreatioLab"}]},{"type":"text","text":" y sé parte de la revolución que está transformando la enseñanza y la industria de los datos."}],"type":"paragraph"},{"text":"KreatioLab: tu guía en la selva oscura del dato","type":"heading","anchor":"KreatioLab-tu-gu%C3%ADa-en-la-selva-oscura-del-dato","level":2},{"inlineContent":[{"type":"text","text":"Inspirados en la “Divina Comedia” de Dante, en KreatioLab no solo ofrecemos educación, sino un viaje épico a través del vasto y a veces intimidante mundo de los datos. Al igual que Dante, que se aventuró por territorios desconocidos guiado por Virgilio, nuestros estudiantes son "},{"type":"strong","inlineContent":[{"text":"acompañados en cada paso de su educación","type":"text"}]},{"type":"text","text":", desde la confusión inicial hasta la claridad y el dominio de las diferentes áreas del dato de la industria."}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"P1"}],"type":"paragraph"},{"text":"El Viaje del Conocimiento","type":"heading","anchor":"El-Viaje-del-Conocimiento","level":2},{"text":"Explorar","type":"heading","anchor":"Explorar","level":3},{"inlineContent":[{"type":"text","text":"Comienzas tu educación estableciendo los fundamentos. "},{"inlineContent":[{"type":"text","text":"Explora"}],"type":"strong"},{"type":"text","text":" las bases del conocimiento de los datos."}],"type":"paragraph"},{"text":"Practica","type":"heading","anchor":"Practica","level":3},{"inlineContent":[{"text":"A medida que avanzas, ","type":"text"},{"inlineContent":[{"type":"text","text":"Practica"}],"type":"strong"},{"text":" aplicando lo aprendido en escenarios reales, puliendo tus habilidades.","type":"text"}],"type":"paragraph"},{"text":"Lidera","type":"heading","anchor":"Lidera","level":3},{"inlineContent":[{"text":"Finalmente, puedes optar por ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Liderar"}]},{"text":", alcanzando la cúspide del conocimiento en inteligencia artificial y los datos.","type":"text"}],"type":"paragraph"},{"text":"Nuestra Misión","type":"heading","anchor":"Nuestra-Misi%C3%B3n","level":3},{"inlineContent":[{"text":"Nuestra misión en KreatioLab es ","type":"text"},{"inlineContent":[{"type":"text","text":"abrir el camino"}],"type":"strong"},{"text":", limpiar la maraña de obstáculos que impiden el avance hacia la comprensión y la innovación en los datos. Estamos aquí para ser tus ","type":"text"},{"inlineContent":[{"text":"guías","type":"text"}],"type":"strong"},{"text":", tus mentores, tu ‘Virgilio’, mientras tú asumes el rol de ‘Dante’ en este viaje transformador.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"P2"}],"type":"paragraph"},{"text":"Conclusión: un llamado a la aventura","type":"heading","anchor":"Conclusi%C3%B3n-un-llamado-a-la-aventura","level":2},{"inlineContent":[{"type":"text","text":"La revolución del dato está aquí y KreatioLab está en la vanguardia, preparándote para el futuro. "},{"type":"strong","inlineContent":[{"text":"Reinvéntate","type":"text"}]},{"type":"text","text":". "},{"type":"strong","inlineContent":[{"type":"text","text":"Transfórmate"}]},{"type":"text","text":". "},{"type":"strong","inlineContent":[{"text":"Evoluciona","type":"text"}]},{"type":"text","text":". "},{"isActive":true,"type":"reference","identifier":"https:\/\/kreatiolab.com\/"},{"type":"text","text":" y sé parte de la Revolución del Conocimiento. Como dijo Dante refiriéndose a su odisea:"}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"“Y así como aquel que con ansias respira, sale del peligroso mar a la orilla, se vuelve hacia el agua peligrosa y reza, así hizo mi alma, que aún volaba, volverse a mirar el paso que nunca persona volvió a pasar”."}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"En "},{"identifier":"https:\/\/kreatiolab.com\/","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}],"overridingTitle":"KreatioLab - Academia de Datos","type":"reference"},{"type":"text","text":", cada paso que tomas es parte de un viaje hacia el descubrimiento y la excelencia en el universo del dato."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"metadata":{"title":"KreatioDocs","modules":[{"name":"KreatioDocs"}],"symbolKind":"module","role":"collection","externalID":"KreatioDocs"},"hierarchy":{"paths":[[]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://KreatioDocs/documentation/KreatioDocs/Deep-Learning-Essentials":{"abstract":[{"type":"text","text":"Proximamente…"}],"kind":"article","url":"\/documentation\/kreatiodocs\/deep-learning-essentials","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Deep-Learning-Essentials","images":[{"type":"icon","identifier":"lock_grey.svg"}],"title":"Deep Learning Essentials","role":"article","type":"topic"},"doc://KreatioDocs/documentation/KreatioDocs/Recursos_y_herramientas":{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Recursos_y_herramientas","role":"collectionGroup","images":[{"type":"icon","identifier":"martillo.png"}],"kind":"article","abstract":[],"type":"topic","title":"Recursos y herramientas","url":"\/documentation\/kreatiodocs\/recursos_y_herramientas"},"doc://KreatioDocs/documentation/KreatioDocs/Data-Engineering-Essentials":{"kind":"article","url":"\/documentation\/kreatiodocs\/data-engineering-essentials","abstract":[],"title":"Data Engineering Essentials","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Data-Engineering-Essentials","type":"topic","role":"collectionGroup"},"robot.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/robot.png"}],"identifier":"robot.png","type":"image"},"rrss.png":{"alt":null,"variants":[{"traits":["1x","light"],"url":"\/i