dentifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestras-Rutas-de-Aprendizaje"],"anchor":"Practica"},{"anchor":"Lidera","identifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Programas-Ejecutivos"],"title":"Lidera"},{"anchor":"Links","identifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestros-mentores","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Testimonios","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Redes_Sociales"],"title":"Links"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs"},"primaryContentSections":[{"content":[{"level":2,"text":"KreatioLab - La Academia de Datos que revoluciona la enseñanza y la industria","anchor":"KreatioLab-La-Academia-de-Datos-que-revoluciona-la-ense%C3%B1anza-y-la-industria","type":"heading"},{"inlineContent":[{"type":"text","text":"En la encrucijada de la educación y la innovación tecnológica, "},{"inlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}],"type":"strong"},{"type":"text","text":" emerge como un faro de cambio radical. Con sedes repartidas entre Europa y Latinoamérica, esta institución no solo se propone transformar cómo se enseña, sino también cómo se construyen los proyectos de datos en la industria actual."}],"type":"paragraph"},{"identifier":"Intro.mp4","type":"video"},{"level":2,"text":"Una misión de cambio e inspiración","anchor":"Una-misi%C3%B3n-de-cambio-e-inspiraci%C3%B3n","type":"heading"},{"inlineContent":[{"text":"El mundo de hoy enfrenta un ciclo vicioso en el que la enseñanza sin inspiración y alejada del ámbito laboral lleva a trabajos monótonos y a una innovación estancada. KreatioLab nace como respuesta a esta problemática, con la convicción de que cambiar la forma de enseñar es el primer paso para revolucionar la industria y la investigación. La academia se posiciona en la vanguardia, dispuesta a cortar las lianas de un sistema obsoleto, guiando a estudiantes y profesionales hacia una era de proyectos innovadores y emprendimientos revolucionarios.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Tutoriales interactivos, módulos de especialización y rutas de aprendizaje.","anchor":"Tutoriales-interactivos-m%C3%B3dulos-de-especializaci%C3%B3n-y-rutas-de-aprendizaje","type":"heading"},{"inlineContent":[{"text":"KreatioLab ofrece una variedad de ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"tutoriales interactivos"}]},{"text":", ","type":"text"},{"type":"strong","inlineContent":[{"text":"módulos de especialización","type":"text"}]},{"text":" y ","type":"text"},{"type":"strong","inlineContent":[{"text":"rutas de aprendizaje","type":"text"}]},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"recomendadas","type":"text"}]},{"text":", destinados a formar a los líderes del mañana en el ámbito de los datos, en particular en estas áreas:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"Data Analytics & Business Intelligence","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"text":"✅ ","type":"text"},{"inlineContent":[{"text":"Data Science: Machine Learning & Deep Learning","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"Data Engineering con AWS","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"text":"✅ ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Artificial Intelligence & Advanced Deep Learning"}]}],"type":"paragraph"},{"anchor":"Metodolog%C3%ADa-y-ventajas-competitivas","type":"heading","text":"Metodología y ventajas competitivas","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"En "},{"type":"strong","inlineContent":[{"type":"text","text":"KreatioLab"}]},{"type":"text","text":", la formación es impartida por "},{"type":"reference","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestros-mentores","isActive":true},{"type":"text","text":" que poseen años de "},{"type":"strong","inlineContent":[{"type":"text","text":"experiencia práctica"}]},{"type":"text","text":" en el ámbito de los datos, muchos de los cuales han liderado equipos y áreas completas dentro de empresas reconocidas."}]},{"anchor":"Historias-de-%C3%A9xito-y-testimonios","type":"heading","text":"Historias de éxito y testimonios","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A lo largo de los años, KreatioLab ha visto cómo sus alumnos se transforman en profesionales inspirados y motivados. Las historias de éxito adornan la academia, con "},{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Testimonios","isActive":true,"type":"reference","overridingTitle":"testimonios","overridingTitleInlineContent":[{"inlineContent":[{"type":"text","text":"testimonios"}],"type":"strong"}]},{"type":"text","text":" de estudiantes que ahora trabajan en diversas posiciones en el área del dato, participan y lideran proyectos y contribuyen a la innovación en múltiples sectores."}]},{"anchor":"C%C3%B3mo-unirse-a-KreatioLab","type":"heading","text":"Cómo unirse a KreatioLab","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"El proceso de inscripción en KreatioLab es muy simple: únete a nuestra comunidad haciendo esta plataforma tuya "},{"type":"strong","inlineContent":[{"text":"sin costo alguno","type":"text"}]},{"type":"text","text":". "},{"type":"strong","inlineContent":[{"type":"text","text":"Comienza a explorar los contenidos que hemos desarrollado para ti de forma gratuita,"}]},{"type":"text","text":" comprenderás el complejo mundo del dato, para luego de construir bases sólidas, elegir tutoriales interactivos, módulos de especialización y junto a un mentor y "},{"type":"strong","inlineContent":[{"text":"recibir orientación sobre cómo iniciar","type":"text"}]},{"type":"text","text":" una "},{"type":"strong","inlineContent":[{"text":"ruta de aprendizaje","type":"text"}]},{"type":"text","text":" y un plan de carrera."}]},{"type":"paragraph","inlineContent":[{"text":"KreatioLab no es solo una academia; es un movimiento. Con cada clase, cada módulo de especialización y cada carrera, está ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"redefiniendo"}]},{"text":" lo que significa aprender y aplicar el conocimiento en el mundo real. ","type":"text"},{"type":"strong","inlineContent":[{"text":"Únete a KreatioLab","type":"text"}]},{"text":" y sé parte de la revolución que está transformando la enseñanza y la industria de los datos.","type":"text"}]},{"anchor":"KreatioLab-tu-gu%C3%ADa-en-la-selva-oscura-del-dato","type":"heading","text":"KreatioLab: tu guía en la selva oscura del dato","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Inspirados en la “Divina Comedia” de Dante, en KreatioLab no solo ofrecemos educación, sino un viaje épico a través del vasto y a veces intimidante mundo de los datos. Al igual que Dante, que se aventuró por territorios desconocidos guiado por Virgilio, nuestros estudiantes son "},{"inlineContent":[{"type":"text","text":"acompañados en cada paso de su educación"}],"type":"strong"},{"type":"text","text":", desde la confusión inicial hasta la claridad y el dominio de las diferentes áreas del dato de la industria."}]},{"type":"paragraph","inlineContent":[{"identifier":"P1","type":"image"}]},{"anchor":"El-Viaje-del-Conocimiento","type":"heading","text":"El Viaje del Conocimiento","level":2},{"anchor":"Explorar","type":"heading","text":"Explorar","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Comienzas tu educación estableciendo los fundamentos. "},{"inlineContent":[{"text":"Explora","type":"text"}],"type":"strong"},{"type":"text","text":" las bases del conocimiento de los datos."}]},{"anchor":"Practica","type":"heading","text":"Practica","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"A medida que avanzas, "},{"inlineContent":[{"text":"Practica","type":"text"}],"type":"strong"},{"type":"text","text":" aplicando lo aprendido en escenarios reales, puliendo tus habilidades."}]},{"anchor":"Lidera","type":"heading","text":"Lidera","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finalmente, puedes optar por "},{"type":"strong","inlineContent":[{"type":"text","text":"Liderar"}]},{"type":"text","text":", alcanzando la cúspide del conocimiento en inteligencia artificial y los datos."}]},{"anchor":"Nuestra-Misi%C3%B3n","type":"heading","text":"Nuestra Misión","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Nuestra misión en KreatioLab es "},{"type":"strong","inlineContent":[{"text":"abrir el camino","type":"text"}]},{"type":"text","text":", limpiar la maraña de obstáculos que impiden el avance hacia la comprensión y la innovación en los datos. Estamos aquí para ser tus "},{"type":"strong","inlineContent":[{"type":"text","text":"guías"}]},{"type":"text","text":", tus mentores, tu ‘Virgilio’, mientras tú asumes el rol de ‘Dante’ en este viaje transformador."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"P2"}]},{"anchor":"Conclusi%C3%B3n-un-llamado-a-la-aventura","type":"heading","text":"Conclusión: un llamado a la aventura","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"La revolución del dato está aquí y KreatioLab está en la vanguardia, preparándote para el futuro. "},{"inlineContent":[{"text":"Reinvéntate","type":"text"}],"type":"strong"},{"type":"text","text":". "},{"inlineContent":[{"type":"text","text":"Transfórmate"}],"type":"strong"},{"type":"text","text":". "},{"inlineContent":[{"type":"text","text":"Evoluciona"}],"type":"strong"},{"type":"text","text":". "},{"identifier":"https:\/\/kreatiolab.com\/","type":"reference","isActive":true},{"type":"text","text":" y sé parte de la Revolución del Conocimiento. Como dijo Dante refiriéndose a su odisea:"}]},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"“Y así como aquel que con ansias respira, sale del peligroso mar a la orilla, se vuelve hacia el agua peligrosa y reza, así hizo mi alma, que aún volaba, volverse a mirar el paso que nunca persona volvió a pasar”.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"En "},{"identifier":"https:\/\/kreatiolab.com\/","type":"reference","isActive":true,"overridingTitle":"KreatioLab - Academia de Datos","overridingTitleInlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}]},{"type":"text","text":", cada paso que tomas es parte de un viaje hacia el descubrimiento y la excelencia en el universo del dato."}]}],"kind":"content"}],"sections":[],"references":{"https://kreatiolab.com/":{"type":"link","titleInlineContent":[{"type":"text","text":"Únete a nosotros"}],"title":"Únete a nosotros","url":"https:\/\/kreatiolab.com\/","identifier":"https:\/\/kreatiolab.com\/"},"silueta_hablando.png":{"alt":null,"type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/silueta_hablando.png"}],"identifier":"silueta_hablando.png"},"doc://KreatioDocs/documentation/KreatioDocs/Bienvenido_comienza_aqui":{"title":"Bienvenido: comienza aquí","images":[{"identifier":"rocket.png","type":"icon"}],"role":"article","type":"topic","url":"\/documentation\/kreatiodocs\/bienvenido_comienza_aqui","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Bienvenido_comienza_aqui","abstract":[],"kind":"article"},"Intro.mp4":{"alt":null,"type":"video","variants":[{"traits":["1x","light"],"url":"\/videos\/KreatioDocs\/Intro.mp4"}],"poster":"Intro.png","identifier":"Intro.mp4"},"doc://KreatioDocs/documentation/KreatioDocs/Programas-Ejecutivos":{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Programas-Ejecutivos","title":"Programas Ejecutivos","url":"\/documentation\/kreatiodocs\/programas-ejecutivos","kind":"article","type":"topic"