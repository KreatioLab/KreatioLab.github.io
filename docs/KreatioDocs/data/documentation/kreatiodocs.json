KreatioDocs\/Nuestros-mentores","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Redes_Sociales"]},{"generated":true,"anchor":"Articles","title":"Articles","identifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestra_consultora"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs"},"metadata":{"role":"collection","symbolKind":"module","modules":[{"name":"KreatioDocs"}],"title":"KreatioDocs","externalID":"KreatioDocs"},"kind":"symbol","primaryContentSections":[{"content":[{"level":2,"text":"KreatioLab - La Academia de Datos que revoluciona la enseñanza y la industria","anchor":"KreatioLab-La-Academia-de-Datos-que-revoluciona-la-ense%C3%B1anza-y-la-industria","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"En la encrucijada de la educación y la innovación tecnológica, "},{"type":"strong","inlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}]},{"type":"text","text":" emerge como un faro de cambio radical. Con sedes repartidas entre Europa y Latinoamérica, esta institución no solo se propone transformar cómo se enseña, sino también cómo se construyen los proyectos de datos en la industria actual."}]},{"identifier":"Intro.mp4","type":"video"},{"level":2,"text":"Una misión de cambio e inspiración","anchor":"Una-misi%C3%B3n-de-cambio-e-inspiraci%C3%B3n","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"El mundo de hoy enfrenta un ciclo vicioso en el que la enseñanza sin inspiración y alejada del ámbito laboral lleva a trabajos monótonos y a una innovación estancada. KreatioLab nace como respuesta a esta problemática, con la convicción de que cambiar la forma de enseñar es el primer paso para revolucionar la industria y la investigación. La academia se posiciona en la vanguardia, dispuesta a cortar las lianas de un sistema obsoleto, guiando a estudiantes y profesionales hacia una era de proyectos innovadores y emprendimientos revolucionarios.","type":"text"}]},{"level":2,"text":"Tutoriales interactivos, módulos de especialización y rutas de aprendizaje.","anchor":"Tutoriales-interactivos-m%C3%B3dulos-de-especializaci%C3%B3n-y-rutas-de-aprendizaje","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KreatioLab ofrece una variedad de "},{"type":"strong","inlineContent":[{"type":"text","text":"tutoriales interactivos"}]},{"type":"text","text":", "},{"type":"strong","inlineContent":[{"type":"text","text":"módulos de especialización"}]},{"type":"text","text":" y "},{"type":"strong","inlineContent":[{"text":"rutas de aprendizaje","type":"text"}]},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"recomendadas"}]},{"type":"text","text":", destinados a formar a los líderes del mañana en el ámbito de los datos, en particular en estas áreas:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"type":"text","text":"Data Analytics & Business Intelligence"}]}]},{"type":"paragraph","inlineContent":[{"text":"✅ ","type":"text"},{"inlineContent":[{"text":"Data Science: Machine Learning & Deep Learning","type":"text"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"✅ ","type":"text"},{"type":"strong","inlineContent":[{"text":"Data Engineering con AWS","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"Artificial Intelligence & Advanced Deep Learning","type":"text"}]}]},{"level":2,"text":"Metodología y ventajas competitivas","anchor":"Metodolog%C3%ADa-y-ventajas-competitivas","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"En "},{"inlineContent":[{"text":"KreatioLab","type":"text"}],"type":"strong"},{"type":"text","text":", la formación es impartida por "},{"type":"reference","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestros-mentores","isActive":true},{"type":"text","text":" que poseen años de "},{"inlineContent":[{"type":"text","text":"experiencia práctica"}],"type":"strong"},{"type":"text","text":" en el ámbito de los datos, muchos de los cuales han liderado equipos y áreas completas dentro de empresas reconocidas."}]},{"level":2,"text":"Historias de éxito y testimonios","anchor":"Historias-de-%C3%A9xito-y-testimonios","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A lo largo de los años, KreatioLab ha visto cómo sus alumnos se transforman en profesionales inspirados y motivados. Las historias de éxito adornan la academia, con "},{"isActive":true,"type":"reference","identifier":"https:\/\/kreatiolab.com\/#testimoniales"},{"type":"text","text":" de estudiantes que ahora trabajan en diversas posiciones en el área del dato, participan y lideran proyectos y contribuyen a la innovación en múltiples sectores."}]},{"level":2,"text":"Cómo unirse a KreatioLab","anchor":"C%C3%B3mo-unirse-a-KreatioLab","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"El proceso de inscripción en KreatioLab es muy simple: únete a nuestra comunidad haciendo esta plataforma tuya "},{"inlineContent":[{"type":"text","text":"sin costo alguno"}],"type":"strong"},{"type":"text","text":". "},{"inlineContent":[{"text":"Comienza a explorar los contenidos que hemos desarrollado para ti de forma gratuita,","type":"text"}],"type":"strong"},{"type":"text","text":" comprenderás el complejo mundo del dato, para luego de construir bases sólidas, elegir tutoriales interactivos, módulos de especialización y junto a un mentor y "},{"inlineContent":[{"text":"recibir orientación sobre cómo iniciar","type":"text"}],"type":"strong"},{"type":"text","text":" una "},{"inlineContent":[{"text":"ruta de aprendizaje","type":"text"}],"type":"strong"},{"type":"text","text":" y un plan de carrera."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KreatioLab no es solo una academia; es un movimiento. Con cada clase, cada módulo de especialización y cada carrera, está "},{"inlineContent":[{"text":"redefiniendo","type":"text"}],"type":"strong"},{"type":"text","text":" lo que significa aprender y aplicar el conocimiento en el mundo real. "},{"inlineContent":[{"type":"text","text":"Únete a KreatioLab"}],"type":"strong"},{"type":"text","text":" y sé parte de la revolución que está transformando la enseñanza y la industria de los datos."}]},{"level":2,"text":"KreatioLab: tu guía en la selva oscura del dato","anchor":"KreatioLab-tu-gu%C3%ADa-en-la-selva-oscura-del-dato","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Inspirados en la “Divina Comedia” de Dante, en KreatioLab no solo ofrecemos educación, sino un viaje épico a través del vasto y a veces intimidante mundo de los datos. Al igual que Dante, que se aventuró por territorios desconocidos guiado por Virgilio, nuestros estudiantes son ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"acompañados en cada paso de su educación"}]},{"text":", desde la confusión inicial hasta la claridad y el dominio de las diferentes áreas del dato de la industria.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"P1"}]},{"level":2,"text":"El Viaje del Conocimiento","anchor":"El-Viaje-del-Conocimiento","type":"heading"},{"level":3,"text":"Explorar","anchor":"Explorar","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Comienzas tu educación estableciendo los fundamentos. ","type":"text"},{"inlineContent":[{"type":"text","text":"Explora"}],"type":"strong"},{"text":" las bases del conocimiento de los datos.","type":"text"}]},{"level":3,"text":"Practica","anchor":"Practica","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A medida que avanzas, ","type":"text"},{"inlineContent":[{"type":"text","text":"Practica"}],"type":"strong"},{"text":" aplicando lo aprendido en escenarios reales, puliendo tus habilidades.","type":"text"}]},{"level":3,"text":"Lidera","anchor":"Lidera","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Finalmente, puedes optar por ","type":"text"},{"inlineContent":[{"text":"Liderar","type":"text"}],"type":"strong"},{"text":", alcanzando la cúspide del conocimiento en inteligencia artificial y los datos.","type":"text"}]},{"level":3,"text":"Nuestra Misión","anchor":"Nuestra-Misi%C3%B3n","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Nuestra misión en KreatioLab es "},{"type":"strong","inlineContent":[{"type":"text","text":"abrir el camino"}]},{"type":"text","text":", limpiar la maraña de obstáculos que impiden el avance hacia la comprensión y la innovación en los datos. Estamos aquí para ser tus "},{"type":"strong","inlineContent":[{"type":"text","text":"guías"}]},{"type":"text","text":", tus mentores, tu ‘Virgilio’, mientras tú asumes el rol de ‘Dante’ en este viaje transformador."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"P2"}]},{"level":2,"text":"Conclusión: un llamado a la aventura","anchor":"Conclusi%C3%B3n-un-llamado-a-la-aventura","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"La revolución del dato está aquí y KreatioLab está en la vanguardia, preparándote para el futuro. ","type":"text"},{"inlineContent":[{"type":"text","text":"Reinvéntate"}],"type":"strong"},{"text":". ","type":"text"},{"inlineContent":[{"text":"Transfórmate","type":"text"}],"type":"strong"},{"text":". ","type":"text"},{"inlineContent":[{"type":"text","text":"Evoluciona"}],"type":"strong"},{"text":". ","type":"text"},{"identifier":"https:\/\/kreatiolab.com\/","isActive":true,"type":"reference"},{"text":" y sé parte de la Revolución del Conocimiento. Como dijo Dante refiriéndose a su odisea:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"text":"“Y así como aquel que con ansias respira, sale del peligroso mar a la orilla, se vuelve hacia el agua peligrosa y reza, así hizo mi alma, que aún volaba, volverse a mirar el paso que nunca persona volvió a pasar”.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"En ","type":"text"},{"isActive":true,"identifier":"https:\/\/kreatiolab.com\/","overridingTitle":"KreatioLab - Academia de Datos","overridingTitleInlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}],"type":"reference"},{"text":", cada paso que tomas es parte de un viaje hacia el descubrimiento y la excelencia en el universo del dato.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[[]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kreatiodocs"]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://KreatioDocs/documentation/KreatioDocs/Agenda_gratis_cafe_con_mentores":{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Agenda_gratis_cafe_con_mentores","abstract":[],"role":"article","url":"\/documentation\/kreatiodocs\/agenda_gratis_cafe_con_mentores","images":[{"identifier":"coffe.png","type":"icon"}],"type":"topic","title":"Agenda gratis café con mentores","kind":"article"},"rocket.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/rocket.png"}],"alt":null,"identifier":"rocket.png","type":"image"},"doc://KreatioDocs/documentation/KreatioDocs/Tu_plataforma_kreatiodocs":{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Tu_plataforma_kreatiodocs","abstract":[{"text":"Descubre tu camino ideal con nuestra exclusiva plataforma.","type":"text"}],"role":"article","url":"\/documentation\/kreatiodocs\/tu_plataforma_kreatiodocs","images":[{"identifier":"robot.png","type":"icon"}],"type":"topic","title":"Tú plataforma: KreatioDocs","kind":"article"},"doc://KreatioDocs/documentation/KreatioDocs/Matematicas-basicas-Calculo-y-Algebra-Lineal":{"abstract":[],"title":"Matemáticas básicas, Cálculo y Álgebra Lineal","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Matematicas-basicas-Calculo-y-Algebra-Li