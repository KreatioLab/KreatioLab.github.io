/\/KreatioDocs\/documentation\/KreatioDocs\/Programas-Ejecutivos"]},{"anchor":"Links","title":"Links","identifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestros-mentores","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Testimonios","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Redes_Sociales"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"KreatioLab - La Academia de Datos que revoluciona la enseñanza y la industria","anchor":"KreatioLab-La-Academia-de-Datos-que-revoluciona-la-ense%C3%B1anza-y-la-industria","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"En la encrucijada de la educación y la innovación tecnológica, "},{"type":"strong","inlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}]},{"type":"text","text":" emerge como un faro de cambio radical. Con sedes repartidas entre Europa y Latinoamérica, esta institución no solo se propone transformar cómo se enseña, sino también cómo se construyen los proyectos de datos en la industria actual."}]},{"type":"video","identifier":"Intro.mp4"},{"type":"heading","text":"Una misión de cambio e inspiración","anchor":"Una-misi%C3%B3n-de-cambio-e-inspiraci%C3%B3n","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"El mundo de hoy enfrenta un ciclo vicioso en el que la enseñanza sin inspiración y alejada del ámbito laboral lleva a trabajos monótonos y a una innovación estancada. KreatioLab nace como respuesta a esta problemática, con la convicción de que cambiar la forma de enseñar es el primer paso para revolucionar la industria y la investigación. La academia se posiciona en la vanguardia, dispuesta a cortar las lianas de un sistema obsoleto, guiando a estudiantes y profesionales hacia una era de proyectos innovadores y emprendimientos revolucionarios."}]},{"type":"heading","text":"Tutoriales interactivos, módulos de especialización y rutas de aprendizaje.","anchor":"Tutoriales-interactivos-m%C3%B3dulos-de-especializaci%C3%B3n-y-rutas-de-aprendizaje","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"KreatioLab ofrece una variedad de "},{"inlineContent":[{"type":"text","text":"tutoriales interactivos"}],"type":"strong"},{"type":"text","text":", "},{"inlineContent":[{"text":"módulos de especialización","type":"text"}],"type":"strong"},{"type":"text","text":" y "},{"inlineContent":[{"type":"text","text":"rutas de aprendizaje"}],"type":"strong"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"recomendadas"}],"type":"strong"},{"type":"text","text":", destinados a formar a los líderes del mañana en el ámbito de los datos, en particular en estas áreas:"}]},{"type":"paragraph","inlineContent":[{"text":"✅ ","type":"text"},{"type":"strong","inlineContent":[{"text":"Data Analytics & Business Intelligence","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"Data Science: Machine Learning & Deep Learning","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"✅ ","type":"text"},{"inlineContent":[{"type":"text","text":"Data Engineering con AWS"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"✅ "},{"type":"strong","inlineContent":[{"text":"Artificial Intelligence & Advanced Deep Learning","type":"text"}]}]},{"level":2,"type":"heading","text":"Metodología y ventajas competitivas","anchor":"Metodolog%C3%ADa-y-ventajas-competitivas"},{"type":"paragraph","inlineContent":[{"text":"En ","type":"text"},{"type":"strong","inlineContent":[{"text":"KreatioLab","type":"text"}]},{"text":", la formación es impartida por ","type":"text"},{"type":"reference","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Nuestros-mentores","isActive":true},{"text":" que poseen años de ","type":"text"},{"type":"strong","inlineContent":[{"text":"experiencia práctica","type":"text"}]},{"text":" en el ámbito de los datos, muchos de los cuales han liderado equipos y áreas completas dentro de empresas reconocidas.","type":"text"}]},{"level":2,"type":"heading","text":"Historias de éxito y testimonios","anchor":"Historias-de-%C3%A9xito-y-testimonios"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A lo largo de los años, KreatioLab ha visto cómo sus alumnos se transforman en profesionales inspirados y motivados. Las historias de éxito adornan la academia, con "},{"type":"reference","overridingTitleInlineContent":[{"type":"strong","inlineContent":[{"text":"testimonios","type":"text"}]}],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Testimonios","overridingTitle":"testimonios","isActive":true},{"type":"text","text":" de estudiantes que ahora trabajan en diversas posiciones en el área del dato, participan y lideran proyectos y contribuyen a la innovación en múltiples sectores."}]},{"level":2,"type":"heading","text":"Cómo unirse a KreatioLab","anchor":"C%C3%B3mo-unirse-a-KreatioLab"},{"type":"paragraph","inlineContent":[{"text":"El proceso de inscripción en KreatioLab es muy simple: únete a nuestra comunidad haciendo esta plataforma tuya ","type":"text"},{"inlineContent":[{"type":"text","text":"sin costo alguno"}],"type":"strong"},{"text":". ","type":"text"},{"inlineContent":[{"type":"text","text":"Comienza a explorar los contenidos que hemos desarrollado para ti de forma gratuita,"}],"type":"strong"},{"text":" comprenderás el complejo mundo del dato, para luego de construir bases sólidas, elegir tutoriales interactivos, módulos de especialización y junto a un mentor y ","type":"text"},{"inlineContent":[{"text":"recibir orientación sobre cómo iniciar","type":"text"}],"type":"strong"},{"text":" una ","type":"text"},{"inlineContent":[{"text":"ruta de aprendizaje","type":"text"}],"type":"strong"},{"text":" y un plan de carrera.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KreatioLab no es solo una academia; es un movimiento. Con cada clase, cada módulo de especialización y cada carrera, está "},{"type":"strong","inlineContent":[{"text":"redefiniendo","type":"text"}]},{"type":"text","text":" lo que significa aprender y aplicar el conocimiento en el mundo real. "},{"type":"strong","inlineContent":[{"type":"text","text":"Únete a KreatioLab"}]},{"type":"text","text":" y sé parte de la revolución que está transformando la enseñanza y la industria de los datos."}]},{"level":2,"type":"heading","text":"KreatioLab: tu guía en la selva oscura del dato","anchor":"KreatioLab-tu-gu%C3%ADa-en-la-selva-oscura-del-dato"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Inspirados en la “Divina Comedia” de Dante, en KreatioLab no solo ofrecemos educación, sino un viaje épico a través del vasto y a veces intimidante mundo de los datos. Al igual que Dante, que se aventuró por territorios desconocidos guiado por Virgilio, nuestros estudiantes son "},{"type":"strong","inlineContent":[{"type":"text","text":"acompañados en cada paso de su educación"}]},{"type":"text","text":", desde la confusión inicial hasta la claridad y el dominio de las diferentes áreas del dato de la industria."}]},{"type":"paragraph","inlineContent":[{"identifier":"P1","type":"image"}]},{"level":2,"type":"heading","text":"El Viaje del Conocimiento","anchor":"El-Viaje-del-Conocimiento"},{"level":3,"type":"heading","text":"Explorar","anchor":"Explorar"},{"type":"paragraph","inlineContent":[{"text":"Comienzas tu educación estableciendo los fundamentos. ","type":"text"},{"inlineContent":[{"type":"text","text":"Explora"}],"type":"strong"},{"text":" las bases del conocimiento de los datos.","type":"text"}]},{"level":3,"type":"heading","text":"Practica","anchor":"Practica"},{"type":"paragraph","inlineContent":[{"text":"A medida que avanzas, ","type":"text"},{"inlineContent":[{"type":"text","text":"Practica"}],"type":"strong"},{"text":" aplicando lo aprendido en escenarios reales, puliendo tus habilidades.","type":"text"}]},{"level":3,"type":"heading","text":"Lidera","anchor":"Lidera"},{"type":"paragraph","inlineContent":[{"text":"Finalmente, puedes optar por ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Liderar"}]},{"text":", alcanzando la cúspide del conocimiento en inteligencia artificial y los datos.","type":"text"}]},{"level":3,"type":"heading","text":"Nuestra Misión","anchor":"Nuestra-Misi%C3%B3n"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Nuestra misión en KreatioLab es "},{"type":"strong","inlineContent":[{"type":"text","text":"abrir el camino"}]},{"type":"text","text":", limpiar la maraña de obstáculos que impiden el avance hacia la comprensión y la innovación en los datos. Estamos aquí para ser tus "},{"type":"strong","inlineContent":[{"type":"text","text":"guías"}]},{"type":"text","text":", tus mentores, tu ‘Virgilio’, mientras tú asumes el rol de ‘Dante’ en este viaje transformador."}]},{"type":"paragraph","inlineContent":[{"identifier":"P2","type":"image"}]},{"level":2,"type":"heading","text":"Conclusión: un llamado a la aventura","anchor":"Conclusi%C3%B3n-un-llamado-a-la-aventura"},{"type":"paragraph","inlineContent":[{"text":"La revolución del dato está aquí y KreatioLab está en la vanguardia, preparándote para el futuro. ","type":"text"},{"inlineContent":[{"text":"Reinvéntate","type":"text"}],"type":"strong"},{"text":". ","type":"text"},{"inlineContent":[{"type":"text","text":"Transfórmate"}],"type":"strong"},{"text":". ","type":"text"},{"inlineContent":[{"type":"text","text":"Evoluciona"}],"type":"strong"},{"text":". ","type":"text"},{"isActive":true,"identifier":"https:\/\/kreatiolab.com\/","type":"reference"},{"text":" y sé parte de la Revolución del Conocimiento. Como dijo Dante refiriéndose a su odisea:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"“Y así como aquel que con ansias respira, sale del peligroso mar a la orilla, se vuelve hacia el agua peligrosa y reza, así hizo mi alma, que aún volaba, volverse a mirar el paso que nunca persona volvió a pasar”."}]}]},{"type":"paragraph","inlineContent":[{"text":"En ","type":"text"},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"KreatioLab - Academia de Datos"}],"identifier":"https:\/\/kreatiolab.com\/","overridingTitle":"KreatioLab - Academia de Datos"},{"text":", cada paso que tomas es parte de un viaje hacia el descubrimiento y la excelencia en el universo del dato.","type":"text"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"collection","modules":[{"name":"KreatioDocs"}],"externalID":"KreatioDocs","title":"KreatioDocs","symbolKind":"module"},"identifier":{"url":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs","interfaceLanguage":"swift"},"references":{"doc://KreatioDocs/documentation/KreatioDocs/Redes_Sociales":{"images":[{"type":"icon","identifier":"rrss.png"}],"kind":"article","title":"Redes Sociales","type":"topic","abstract":[],"url":"\/documentation\/kreatiodocs\/redes_sociales","role":"article","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Redes_Sociales"},"PR_TOG.png":{"variants":[{"url":"\/images\/KreatioDocs\/PR_TOG.png","traits":["1x","light"]}],"identifier":"PR_TOG.png","alt":null,"type":"image"},"doc://KreatioDocs/documentation/KreatioDocs/Recursos_y_herramientas":{"title":"Recursos y herramientas","kind":"article","role":"collectionGroup","images":[{"type":"icon","identifier":"martillo.png"}],"abstract":[],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Recursos_y_herramientas","url":"\/documentation\/kreatiodocs\/recursos_y_herramientas","type":"topic"},"doc://KreatioDocs/documentation/KreatioDocs/Probabilidad-Estadistica-Descriptiva-e-Inferencial":{"url":"\/documentation\/kreatiodocs\/probabilidad-estadistica-descriptiva-e-inferencial","role":"collectionGroup","type":"topic","abstract":[],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Probabilidad-Estadistica-Descriptiva-e