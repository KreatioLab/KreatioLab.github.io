oDocs/Programacion":{"url":"\/documentation\/kreatiodocs\/programacion","kind":"article","role":"collectionGroup","abstract":[],"type":"topic","title":"Programación","images":[{"identifier":"PR_TOG.png","type":"card"}],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Programacion"},"doc://KreatioDocs/documentation/KreatioDocs/Definiendo-Funciones-en-Programacion":{"url":"\/documentation\/kreatiodocs\/definiendo-funciones-en-programacion","kind":"article","role":"article","title":"Definiendo Funciones en Programación","abstract":[{"type":"text","text":"Uso y Creación de Funciones en Python."}],"type":"topic","images":[{"type":"card","identifier":"DFP1.png"}],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Definiendo-Funciones-en-Programacion"}}}