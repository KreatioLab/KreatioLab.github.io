 max_value = value3","   ...:     return max_value","   ...:","","In [2]: maximum(12, 27, 36)","Out[2]: 36","","In [3]: maximum(12.3, 45.6, 9.7)","Out[3]: 45.6","","In [4]: maximum('yellow', 'red', 'orange')","Out[4]: 'yellow'"],"type":"codeListing"},{"inlineContent":[{"type":"image","identifier":"FMPP"}],"type":"paragraph"},{"name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":"Mantén el código limpio y conciso. Evita líneas en blanco innecesarias, especialmente en definiciones de funciones para mantener la legibilidad y eficiencia en Python."}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"type":"text","text":"No colocamos líneas en blanco arriba y abajo de las declaraciones "},{"code":"if","type":"codeVoice"},{"type":"text","text":", porque presionar retorno en una línea en blanco en modo interactivo completa la definición de la función."}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Al mezclar tipos en funciones como ","type":"text"},{"inlineContent":[{"type":"codeVoice","code":"maximum"}],"type":"strong"},{"text":", sé consciente de las limitaciones de Python. Por ejemplo, comparar directamente cadenas y números puede resultar en un ","type":"text"},{"inlineContent":[{"type":"codeVoice","code":"TypeError"}],"type":"strong"},{"text":".","type":"text"}]}],"type":"aside"},{"anchor":"Funcionalidad-y-Flexibilidad-de-maximum","type":"heading","level":3,"text":"Funcionalidad y Flexibilidad de `maximum`"},{"inlineContent":[{"text":"También puedes llamar a ","type":"text"},{"type":"codeVoice","code":"maximum"},{"text":" con tipos mixtos, como ","type":"text"},{"type":"codeVoice","code":"int"},{"text":"s y ","type":"text"},{"type":"codeVoice","code":"float"},{"text":"s:","type":"text"}],"type":"paragraph"},{"syntax":"python","code":["In [5]: maximum(13.5, -3, 7)","Out[5]: 13.5"],"type":"codeListing"},{"inlineContent":[{"text":"La llamada ","type":"text"},{"type":"codeVoice","code":"maximum(13.5, 'hello', 7)"},{"text":" resulta en ","type":"text"},{"type":"codeVoice","code":"TypeError"},{"text":" porque las cadenas y los números no pueden ser comparados entre sí con el operador mayor que (","type":"text"},{"type":"codeVoice","code":">"},{"text":").","type":"text"}],"type":"paragraph"},{"anchor":"Definici%C3%B3n-de-la-Funci%C3%B3n-maximum","type":"heading","level":3,"text":"Definición de la Función `maximum`"},{"inlineContent":[{"text":"La función ","type":"text"},{"code":"maximum","type":"codeVoice"},{"text":" especifica tres parámetros en una lista separada por comas. Los argumentos del fragmento ","type":"text"},{"code":"[2]","type":"codeVoice"},{"text":" ","type":"text"},{"code":"12","type":"codeVoice"},{"text":", ","type":"text"},{"code":"27","type":"codeVoice"},{"text":" y ","type":"text"},{"code":"36","type":"codeVoice"},{"text":" se asignan a los parámetros ","type":"text"},{"code":"value1","type":"codeVoice"},{"text":", ","type":"text"},{"code":"value2","type":"codeVoice"},{"text":" y ","type":"text"},{"code":"value3","type":"codeVoice"},{"text":", respectivamente.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Para determinar el valor más grande, procesamos un valor a la vez:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Inicialmente, asumimos que value1 contiene el valor más grande, así que lo asignamos a la variable local "},{"type":"codeVoice","code":"max_value"},{"type":"text","text":". Por supuesto, es posible que "},{"type":"codeVoice","code":"value2"},{"type":"text","text":" o "},{"type":"codeVoice","code":"alue3"},{"type":"text","text":" contengan el valor más grande real, así que aún debemos comparar cada uno de estos con "},{"type":"codeVoice","code":"max_value"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"El primer if luego verifica "},{"type":"codeVoice","code":"value2 > max_value"},{"type":"text","text":", y si esta condición es "},{"type":"codeVoice","code":"True"},{"type":"text","text":" asigna "},{"type":"codeVoice","code":"value2"},{"type":"text","text":" a "},{"type":"codeVoice","code":"max_value"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"El segundo if verifica "},{"type":"codeVoice","code":"value3 > max_value"},{"type":"text","text":", y si esta condición es "},{"type":"codeVoice","code":"True"},{"type":"text","text":" asigna "},{"type":"codeVoice","code":"value3"},{"type":"text","text":" a "},{"type":"codeVoice","code":"max_value"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Ahora, "},{"type":"codeVoice","code":"max_value"},{"type":"text","text":" contiene el valor más grande, así que lo devolvemos. Cuando el control regresa al llamador, los parámetros "},{"type":"codeVoice","code":"value1"},{"type":"text","text":", "},{"type":"codeVoice","code":"value2"},{"type":"text","text":" y "},{"type":"codeVoice","code":"value3"},{"type":"text","text":" y la variable "},{"type":"codeVoice","code":"max_value"},{"type":"text","text":" en el bloque de la función—que son todas variables locales—ya no existen."}],"type":"paragraph"},{"anchor":"Optimizaci%C3%B3n-y-Herramientas-Incorporadas-en-Python","type":"heading","level":2,"text":"Optimización y Herramientas Incorporadas en Python"},{"anchor":"Funciones-Incorporadas-de-Python-max-y-min","type":"heading","level":3,"text":"Funciones Incorporadas de Python `max` y `min`"},{"inlineContent":[{"type":"text","text":"Para muchas tareas comunes, las capacidades que necesitas ya existen en Python."}],"type":"paragraph"},{"name":"Tip","style":"tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Aprovecha las funciones incorporadas de Python para optimizar tu código. Esto no solo ahorra tiempo, sino también mejora la confiabilidad y eficiencia de tu programa.