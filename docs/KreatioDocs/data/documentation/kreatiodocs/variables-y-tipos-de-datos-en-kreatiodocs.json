a realizar. La sentencia anterior crea "},{"type":"codeVoice","code":"x"},{"type":"text","text":" y utiliza el símbolo de "},{"type":"strong","inlineContent":[{"text":"asignación (=)","type":"text"}]},{"type":"text","text":" para darle un valor a "},{"type":"codeVoice","code":"x"},{"type":"text","text":". La sentencia completa es una "},{"type":"strong","inlineContent":[{"type":"text","text":"sentencia de asignación"}]},{"type":"text","text":" que leemos como "},{"type":"codeVoice","code":"x se le asigna el valor 7"},{"type":"text","text":". La mayoría de las sentencias terminan al final de la línea, aunque es posible que las sentencias abarquen más de una línea. La siguiente sentencia crea la variable "},{"type":"codeVoice","code":"y"},{"type":"text","text":" y le asigna el valor "},{"type":"codeVoice","code":"3"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"python","type":"codeListing","code":["In [3]: y = 3"]},{"text":"Añadiendo valores de variables y visualizando el resultado","anchor":"A%C3%B1adiendo-valores-de-variables-y-visualizando-el-resultado","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Ahora puedes usar los valores de "},{"type":"codeVoice","code":"x"},{"type":"text","text":" y "},{"type":"codeVoice","code":"y"},{"type":"text","text":" en expresiones:"}],"type":"paragraph"},{"syntax":"python","type":"codeListing","code":["In [4]: x + y","Out[4]: 10"]},{"inlineContent":[{"type":"text","text":"El símbolo "},{"type":"codeVoice","code":"+"},{"type":"text","text":" es el "},{"type":"strong","inlineContent":[{"type":"text","text":"operador de suma."}]},{"type":"text","text":" Es un "},{"type":"strong","inlineContent":[{"text":"operador binario","type":"text"}]},{"type":"text","text":" porque tiene "},{"type":"emphasis","inlineContent":[{"type":"text","text":"dos"}]},{"type":"text","text":" operandos (en este caso, las variables "},{"type":"codeVoice","code":"x"},{"type":"text","text":" y "},{"type":"codeVoice","code":"y"},{"type":"text","text":") sobre los cuales realiza su operación."}],"type":"paragraph"},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"Utilizar nombres de variables descriptivos puede hacer que tu código sea más legible y fácil de mantener.","type":"text"}]}],"type":"aside"},{"anchor":"C%C3%A1lculos-en-sentencias-de-asignaci%C3%B3n","level":3,"text":"Cálculos en sentencias de asignación","type":"heading"},{"inlineContent":[{"text":"A menudo guardarás resultados de cálculos para su uso posterior. La siguiente sentencia de asignación suma los valores de las variables ","type":"text"},{"code":"x","type":"codeVoice"},{"text":" y ","type":"text"},{"code":"y","type":"codeVoice"},{"text":" y asigna el resultado a la variable ","type":"text"},{"code":"total","type":"codeVoice"},{"text":", que luego mostramos:","type":"text"}],"type":"paragraph"},{"syntax":"python","code":["In [5]: total = x + y","In [6]: total","Out[6]: 10"],"type":"codeListing"},{"inlineContent":[{"text":"El fragmento ","type":"text"},{"code":"[5]","type":"codeVoice"},{"text":" se lee como ","type":"text"},{"code":"total se le asigna el valor de x + y","type":"codeVoice"},{"text":". El símbolo ","type":"text"},{"code":"=","type":"codeVoice"},{"text":" no es un operador. El lado derecho del símbolo ","type":"text"},{"code":"=","type":"codeVoice"},{"text":" siempre se ejecuta primero, luego el resultado se asigna a la variable del lado izquierdo del símbolo.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"La sentencia de asignación en Python es una operación que asigna un valor a una variable, lo que puede ser diferente en otros lenguajes de programación donde "},{"type":"codeVoice","code":"="},{"type":"text","text":" es considerado un operador de comparación."}]}],"type":"aside"},{"anchor":"Estilo-Python","level":3,"text":"Estilo Python","type":"heading"},{"inlineContent":[{"text":"La ","type":"text"},{"inlineContent":[{"text":"Guía de Estilo para el Código Python","type":"text"}],"type":"emphasis"},{"text":" te ayuda a escribir código que se ajuste a las convenciones de codificación de Python. La guía de estilo recomienda insertar un espacio a cada lado del símbolo de asignación ","type":"text"},{"code":"=","type":"codeVoice"},{"text":" y operadores binarios como ","type":"text"},{"code":"+","type":"codeVoice"},{"text":" para hacer que los programas sean más legibles.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"https:\/\/www.python.org\/dev\/peps\/pep-0008\/","type":"reference","isActive":true}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Seguir las guías de estilo no sólo hace tu código más legible para otros, sino que también puede ayudar a prevenir errores."}],"type":"paragraph"}],"type":"aside"},{"anchor":"Nombres-de-variables","level":3,"text":"Nombres de variables","type":"heading"},{"inlineContent":[{"type":"text","text":"Un nombre de variable, como "},{"code":"x","type":"codeVoice"},{"type":"text","text":", es un "},{"inlineContent":[{"text":"identificador","type":"text"}],"type":"strong"},{"type":"text","text":". Cada identificador puede constar de letras, dígitos y guiones bajos ("},{"code":"_","type":"codeVoice"},{"type":"text","text":") pero no puede comenzar con un dígito. Python distingue entre mayúsculas y minúsculas, lo que se llama "},{"code":"case sensitive","type":"codeVoice"},{"type":"text","text":", por lo que "},{"code":"number","type":"codeVoice"},{"type":"text","text":" y "},{"code":"Number","type":"codeVoice"},{"type":"text","text":" son identificadores diferentes porque uno comienza con una letra minúscula y el otro con una letra mayúscula."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"Python 3 permite el uso de caracteres Unicode para los nombres de las variables, lo que significa que puedes usar una variedad de símbolos y caracteres de otros idiomas como identificadores.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"anchor":"Tipos","level":3,"text":"Tipos","type":"heading"},{"inlineContent":[{"type":"text","text":"Cada valor en Python tiene un "},{"type":"strong","inlineContent":[{"type":"text","text":"tipo"}]},{"type":"text","text":" que indica el tipo de dato que representa el valor. Puedes ver el tipo de un valor, como en:"}],"type":"paragraph"},{"syntax":"python","code":["In [7]: type(x)","Out[7]: int","","In [8]: type(10.5)","Out[8]: float"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"La variable "},{"type":"codeVoice","code":"x"},{"type":"text","text":" contiene el valor entero "},{"type":"codeVoice","code":"7"},{"type":"text","text":" (del fragmento "},{"type":"codeVoice","code":"[2]"},{"type":"text","text":"), por lo que Python muestra "},{"type":"codeVoice","code":"int"},{"type":"text","text":" (abreviatura de entero). El valor "},{"type":"codeVoice","code":"10.5"},{"type":"text","text":" es un "},{"type":"strong","inlineContent":[{"type":"text","text":"número de punto flotante"}]},{"type":"text","text":" (es decir, un número con un punto decimal), por lo que Python muestra "},{"type":"codeVoice","code":"float"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"La ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"función incorporada"}]},{"text":" ","type":"text"},{"type":"codeVoice","code":"type"},{"text":" de Python determina el tipo de un valor. Una ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"función"}]},{"text":" realiza una tarea cuando la ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"llamas"}]},{"text":" escribiendo su nombre, seguido de paréntesis, ","type":"text"},{"type":"codeVoice","code":"()"},{"text":". Los paréntesis contienen el ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"argumento"}]},{"text":" de la función—los datos que la función ","type":"text"},{"type":"codeVoice","code":"type"},{"text":" necesita para realizar su tarea. Crearás funciones ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"personalizadas","type":"text"}]},{"text":" en las secciones posteriores de ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"KreatioDocs","type":"text"}]},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"VTDK2","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"“La programación es como escribir un libro… excepto que si omites una sola coma en cualquier parte, la narrativa entera se desploma y pierde sentido.”","type":"text"}]},{"type":"text","text":" - Fernando E. Quintana"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Un viaje por el núcleo de la programación.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kreatiodocs\/variables-y-tipos-de-datos-en-kreatiodocs"]}],"hierarchy":{"paths":[["doc:\/\/KreatioDocs\/documentation\/KreatioDocs","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Programacion","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Iniciando-el-Camino-en-Python-Essentials"]]},"references":{"CMK1.png":{"variants":[{"url":"\/images\/KreatioDocs\/CMK1.png","traits":["1x","light"]}],"alt":null,"type":"image","identifier":"CMK1.png"},"doc://KreatioDocs/documentation/KreatioDocs/Calculos-Matematicos-en-KreatioDocs":{"abstract":[{"text":"La precisión de la aritmética en la programación.","type":"text"}],"type":"topic","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Calculos-Matematicos-en-KreatioDocs","url":"\/documentation\/kreatiodocs\/calculos-matematicos-en-kreatiodocs","images":[{"type":"card","identifier":"CMK1.png"}],"kind":"article","role":"article","title":"Cálculos Matemáticos en KreatioDocs"},"VTDK1":{"variants":[{"url":"\/images\