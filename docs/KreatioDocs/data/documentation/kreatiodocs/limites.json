ng":{"type":"image","variants":[{"url":"\/images\/KreatioDocs\/LIM3.png","traits":["1x","light"]}],"identifier":"LIM3.png","alt":"Una función que se acerca infinitamente a 0 pero nunca lo alcanza"},"doc://KreatioDocs/documentation/KreatioDocs":{"type":"topic","url":"\/documentation\/kreatiodocs","abstract":[],"role":"collection","title":"KreatioDocs","kind":"symbol","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs"},"DERP1.png":{"type":"image","identifier":"DERP1.png","alt":null,"variants":[{"url":"\/images\/KreatioDocs\/DERP1.png","traits":["1x","light"]}]},"LIM4":{"type":"image","variants":[{"url":"\/images\/KreatioDocs\/LIM4.svg","svgID":"MJX-53-TEX-N-6C","traits":["1x","light"]},{"url":"\/images\/KreatioDocs\/LIM4~dark.svg","svgID":"MJX-53-TEX-N-6C","traits":["1x","dark"]}],"identifier":"LIM4","alt":"\\lim\\limits_{x \\to \\infty} \\frac{1}{x} = 0"}}}