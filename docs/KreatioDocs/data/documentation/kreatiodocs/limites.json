-TEX-N-6C","url":"\/images\/KreatioDocs\/LIM4.svg"},{"traits":["1x","dark"],"svgID":"MJX-53-TEX-N-6C","url":"\/images\/KreatioDocs\/LIM4~dark.svg"}],"identifier":"LIM4"},"INT1.png":{"alt":null,"identifier":"INT1.png","variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/INT1.png"}],"type":"image"},"doc://KreatioDocs/documentation/KreatioDocs/La-Regla-de-la-Cadena":{"images":[{"type":"card","identifier":"RC1.png"}],"abstract":[{"text":"La Importancia del Cálculo en el Deep Learning.","type":"text"}],"url":"\/documentation\/kreatiodocs\/la-regla-de-la-cadena","title":"La Regla de la Cadena","role":"article","type":"topic","kind":"article","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/La-Regla-de-la-Cadena"},"LIM1":{"type":"image","alt":null,"variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/LIM1.png"}],"identifier":"LIM1"}}}