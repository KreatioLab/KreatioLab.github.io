{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/KreatioDocs\/documentation\/KreatioDocs","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Probabilidad-Estadistica-Descriptiva-e-Inferencial"]]},"seeAlsoSections":[{"anchor":"Presagios-del-Más-Allá","title":"Presagios del Más Allá","generated":true,"identifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Estadistica-Descriptiva","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Distribucion-Normal","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/La-Funcion-de-Densidad-de-Probabilidad-PDF"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/kreatiodocs\/z-scores"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Introducción al Z-Score","anchor":"Introducci%C3%B3n-al-Z-Score","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Es común "},{"type":"emphasis","inlineContent":[{"text":"re-escalar","type":"text"}]},{"type":"text","text":" una distribución normal para que la media sea 0 y la desviación estándar sea 1, lo que se conoce como la "},{"type":"strong","inlineContent":[{"text":"distribución normal estándar","type":"text"}]},{"type":"text","text":". Esto facilita comparar la dispersión de una distribución normal con otra, incluso si tienen medias y varianzas diferentes."}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS1","type":"image"}],"type":"paragraph"},{"text":"Fórmula del Z-Score","anchor":"F%C3%B3rmula-del-Z-Score","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"De particular importancia con la distribución normal estándar es que expresa todos los valores de "},{"inlineContent":[{"type":"text","text":"x"}],"type":"emphasis"},{"type":"text","text":" en términos de desviaciones estándar, conocidas como puntuaciones "},{"inlineContent":[{"type":"text","text":"Z"}],"type":"emphasis"},{"type":"text","text":". Convertir un valor "},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"type":"text","text":" en una puntuación "},{"inlineContent":[{"type":"text","text":"Z"}],"type":"emphasis"},{"type":"text","text":" utiliza una fórmula básica de "},{"inlineContent":[{"text":"escalado","type":"text"}],"type":"emphasis"},{"type":"text","text":":"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS2"}],"type":"paragraph"},{"text":"Aplicación Práctica del Z-Score","anchor":"Aplicaci%C3%B3n-Pr%C3%A1ctica-del-Z-Score","level":3,"type":"heading"},{"inlineContent":[{"text":"Aquí hay un ejemplo. Tenemos dos casas de dos barrios diferentes. El Barrio ","type":"text"},{"inlineContent":[{"text":"A","type":"text"}],"type":"emphasis"},{"text":" tiene un valor medio de las casas de $140,000 y una desviación estándar de $3,000. El Barrio ","type":"text"},{"inlineContent":[{"text":"B","type":"text"}],"type":"emphasis"},{"text":" tiene un valor medio de las casas de $800,000 y una desviación estándar de $10,000.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS3"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS4"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS5","type":"image"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS6","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Ahora tenemos dos casas de cada barrio. La Casa A del barrio ","type":"text"},{"inlineContent":[{"type":"text","text":"A"}],"type":"emphasis"},{"text":" vale $150,000 y la Casa ","type":"text"},{"inlineContent":[{"type":"text","text":"B"}],"type":"emphasis"},{"text":" del barrio B vale $815,000. ¿Cuál casa es más cara en relación con la casa promedio de su barrio?","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS7"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS8","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Si expresamos estos dos valores en términos de desviaciones estándar, podemos compararlos en relación con la media de cada barrio. Usamos la fórmula de puntuación ","type":"text"},{"inlineContent":[{"type":"text","text":"Z"}],"type":"emphasis"},{"text":":","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS9","type":"image"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS10","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS11"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Por lo tanto, la casa en el barrio "},{"inlineContent":[{"text":"A","type":"text"}],"type":"emphasis"},{"type":"text","text":" es en realidad mucho más cara en relación con su barrio que la casa en el barrio "},{"inlineContent":[{"text":"B","type":"text"}],"type":"emphasis"},{"type":"text","text":", ya que tienen puntuaciones Z de 3.333 y 1.5, respectivamente."}],"type":"paragraph"},{"text":"Programando con Z-Scores","anchor":"Programando-con-Z-Scores","level":3,"type":"heading"},{"inlineContent":[{"text":"Así es como podemos convertir un valor x proveniente de una distribución dada con una media y desviación estándar en una puntuación ","type":"text"},{"inlineContent":[{"type":"text","text":"Z"}],"type":"emphasis"},{"text":" y viceversa, como se muestra en el ","type":"text"},{"inlineContent":[{"text":"Ejemplo 1.1","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Ejemplo 1.1. Convertir puntuaciones Z en valores x y viceversa"}]}],"type":"paragraph"},{"syntax":"python","code":["def z_score(x, media, desviacion):","    return (x - media) \/ desviacion","","def z_to_x(z, media, desviacion):","    return (z * desviacion) + media","","media = 140000","desviacion = 3000","x = 150000","","# Convertir a puntuación Z y luego volver a X","z = z_score(x, media, desviacion)","volver_a_x = z_to_x(z, media, desviacion)","","print(\"Puntuación Z: {}\".format(z))  # Puntuación Z: 3.333","print(\"De vuelta a X: {}\".format(volver_a_x))  # De vuelta a X: 150000.0",""],"type":"codeListing"},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"La interpretación del ","type":"text"},{"inlineContent":[{"type":"text","text":"Z-Score"}],"type":"strong"},{"text":" es crucial en análisis estadísticos. Asegúrate de entender el contexto antes de sacar conclusiones.","type":"text"}]}],"type":"aside"},{"inlineContent":[{"identifier":"ZS12","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"La función ","type":"text"},{"code":"z_score()","type":"codeVoice"},{"text":" toma un valor x y lo escala en términos de desviaciones estándar, dada una media y desviación estándar. La función ","type":"text"},{"code":"z_to_x()","type":"codeVoice"},{"text":" toma una puntuación ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Z"}]},{"text":" y la convierte de nuevo en un valor ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"x","type":"text"}]},{"text":". Estudiando las dos funciones, puedes ver su relación algebraica, una resolviendo para la puntuación ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Z","type":"text"}]},{"text":" y la otra para el valor ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"x","type":"text"}]},{"text":". Luego convertimos un valor x de 8.0 en una puntuación ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Z"}]},{"text":" de 3.333 y luego convertimos esa puntuación ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Z"}]},{"text":" de nuevo en un valor ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"text":".","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"COEFICIENTE DE VARIACIÓN. Una herramienta útil para medir la dispersión es el coeficiente de variación. Compara dos distribuciones y cuantifica cuán dispersa está cada una de ellas. Es simple de calcular: divide la desviación estándar entre la media."}],"type":"paragraph"}],"type":"aside"},{"inlineContent":[{"type":"text","text":"Acá te dejo la fórmula junto con el ejemplo comparando dos barrios:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS13"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS14","type":"image"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS15","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Como se puede ver acá, el barrio "},{"inlineContent":[{"type":"text","text":"A"}],"type":"emphasis"},{"type":"text","text":", aunque más barato que el barrio "},{"inlineContent":[{"type":"text","text":"B"}],"type":"emphasis"},{"type":"text","text":", tiene más dispersión y, por lo tanto, más diversidad de precios que el barrio "},{"inlineContent":[{"text":"B","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"“Las matemáticas, vistas correctamente, poseen no solo verdad, sino también suprema belleza.”"}]},{"type":"text","text":" - Bertrand Russell"}],"type":"paragraph"}]}],"kind":"article","abstract":[{"type":"text","text":"Una Mirada al Z-Score y Coeficiente de Variación."}],"metadata":{"modules":[{"name":"KreatioDocs"}],"role":"article","title":"Z-Scores","roleHeading":"Artículo","images":[{"type":"card","identifier":"ZS1.png"}]},"sections":[],"identifier":{"url":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Z-Scores","interfaceLanguage":"swift"},"references":{"ZS15":{"alt":"cvB = \\frac{10000}{800000} = 0.0125","variants":[{"url":"\/images\/KreatioDocs\/ZS15.svg","traits":["1x","light"],"svgID":"MJX-45-TEX-I-1D450"},{"url":"\/images\/KreatioDocs\/ZS15~dark.svg","traits":["1x","dark"],"svgID":"MJX-45-TEX-I-1D450"}],"identifier":"ZS15","type":"image"},"doc://KreatioDocs/documentation/KreatioDocs":{"identifier":"doc:\/\/KreatioDo