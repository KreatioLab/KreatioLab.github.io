{"hierarchy":{"paths":[["doc:\/\/KreatioDocs\/documentation\/KreatioDocs","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Probabilidad-Estadistica-Descriptiva-e-Inferencial"]]},"metadata":{"roleHeading":"Artículo","modules":[{"name":"KreatioDocs"}],"role":"article","title":"Z-Scores","images":[{"type":"card","identifier":"ZS1.png"}]},"seeAlsoSections":[{"title":"Presagios del Más Allá","generated":true,"identifiers":["doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Estadistica-Descriptiva","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Distribucion-Normal","doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/La-Funcion-de-Densidad-de-Probabilidad-PDF"],"anchor":"Presagios-del-Más-Allá"}],"abstract":[{"type":"text","text":"Una Mirada al Z-Score y Coeficiente de Variación."}],"sections":[],"primaryContentSections":[{"content":[{"text":"Introducción al Z-Score","anchor":"Introducci%C3%B3n-al-Z-Score","level":2,"type":"heading"},{"inlineContent":[{"text":"Es común ","type":"text"},{"inlineContent":[{"text":"re-escalar","type":"text"}],"type":"emphasis"},{"text":" una distribución normal para que la media sea 0 y la desviación estándar sea 1, lo que se conoce como la ","type":"text"},{"inlineContent":[{"type":"text","text":"distribución normal estándar"}],"type":"strong"},{"text":". Esto facilita comparar la dispersión de una distribución normal con otra, incluso si tienen medias y varianzas diferentes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS1","type":"image"}],"type":"paragraph"},{"text":"Fórmula del Z-Score","anchor":"F%C3%B3rmula-del-Z-Score","level":3,"type":"heading"},{"inlineContent":[{"text":"De particular importancia con la distribución normal estándar es que expresa todos los valores de ","type":"text"},{"inlineContent":[{"text":"x","type":"text"}],"type":"emphasis"},{"text":" en términos de desviaciones estándar, conocidas como puntuaciones ","type":"text"},{"inlineContent":[{"type":"text","text":"Z"}],"type":"emphasis"},{"text":". Convertir un valor ","type":"text"},{"inlineContent":[{"type":"text","text":"x"}],"type":"emphasis"},{"text":" en una puntuación ","type":"text"},{"inlineContent":[{"text":"Z","type":"text"}],"type":"emphasis"},{"text":" utiliza una fórmula básica de ","type":"text"},{"inlineContent":[{"text":"escalado","type":"text"}],"type":"emphasis"},{"text":":","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS2","type":"image"}],"type":"paragraph"},{"text":"Aplicación Práctica del Z-Score","anchor":"Aplicaci%C3%B3n-Pr%C3%A1ctica-del-Z-Score","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Aquí hay un ejemplo. Tenemos dos casas de dos barrios diferentes. El Barrio "},{"type":"emphasis","inlineContent":[{"text":"A","type":"text"}]},{"type":"text","text":" tiene un valor medio de las casas de $140,000 y una desviación estándar de $3,000. El Barrio "},{"type":"emphasis","inlineContent":[{"text":"B","type":"text"}]},{"type":"text","text":" tiene un valor medio de las casas de $800,000 y una desviación estándar de $10,000."}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS3","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS4"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS5","type":"image"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS6","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Ahora tenemos dos casas de cada barrio. La Casa A del barrio ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"A","type":"text"}]},{"text":" vale $150,000 y la Casa ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"B"}]},{"text":" del barrio B vale $815,000. ¿Cuál casa es más cara en relación con la casa promedio de su barrio?","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS7","type":"image"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS8","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Si expresamos estos dos valores en términos de desviaciones estándar, podemos compararlos en relación con la media de cada barrio. Usamos la fórmula de puntuación "},{"type":"emphasis","inlineContent":[{"text":"Z","type":"text"}]},{"type":"text","text":":"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS9"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS10","type":"image"}],"type":"paragraph"},{"inlineContent":[{"identifier":"ZS11","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"Por lo tanto, la casa en el barrio ","type":"text"},{"inlineContent":[{"type":"text","text":"A"}],"type":"emphasis"},{"text":" es en realidad mucho más cara en relación con su barrio que la casa en el barrio ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"B","type":"text"}]},{"text":", ya que tienen puntuaciones Z de 3.333 y 1.5, respectivamente.","type":"text"}],"type":"paragraph"},{"anchor":"Programando-con-Z-Scores","text":"Programando con Z-Scores","level":3,"type":"heading"},{"inlineContent":[{"text":"Así es como podemos convertir un valor x proveniente de una distribución dada con una media y desviación estándar en una puntuación ","type":"text"},{"inlineContent":[{"text":"Z","type":"text"}],"type":"emphasis"},{"text":" y viceversa, como se muestra en el ","type":"text"},{"inlineContent":[{"text":"Ejemplo 1.1","type":"text"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Ejemplo 1.1. Convertir puntuaciones Z en valores x y viceversa","type":"text"}],"type":"strong"}],"type":"paragraph"},{"syntax":"python","code":["def z_score(x, media, desviacion):","    return (x - media) \/ desviacion","","def z_to_x(z, media, desviacion):","    return (z * desviacion) + media","","media = 140000","desviacion = 3000","x = 150000","","# Convertir a puntuación Z y luego volver a X","z = z_score(x, media, desviacion)","volver_a_x = z_to_x(z, media, desviacion)","","print(\"Puntuación Z: {}\".format(z))  # Puntuación Z: 3.333","print(\"De vuelta a X: {}\".format(volver_a_x))  # De vuelta a X: 150000.0",""],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"La interpretación del ","type":"text"},{"inlineContent":[{"text":"Z-Score","type":"text"}],"type":"strong"},{"text":" es crucial en análisis estadísticos. Asegúrate de entender el contexto antes de sacar conclusiones.","type":"text"}]}],"name":"Tip","type":"aside","style":"tip"},{"inlineContent":[{"identifier":"ZS12","type":"image"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"La función "},{"code":"z_score()","type":"codeVoice"},{"type":"text","text":" toma un valor x y lo escala en términos de desviaciones estándar, dada una media y desviación estándar. La función "},{"code":"z_to_x()","type":"codeVoice"},{"type":"text","text":" toma una puntuación "},{"type":"emphasis","inlineContent":[{"text":"Z","type":"text"}]},{"type":"text","text":" y la convierte de nuevo en un valor "},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"type":"text","text":". Estudiando las dos funciones, puedes ver su relación algebraica, una resolviendo para la puntuación "},{"type":"emphasis","inlineContent":[{"text":"Z","type":"text"}]},{"type":"text","text":" y la otra para el valor "},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"type":"text","text":". Luego convertimos un valor x de 8.0 en una puntuación "},{"type":"emphasis","inlineContent":[{"text":"Z","type":"text"}]},{"type":"text","text":" de 3.333 y luego convertimos esa puntuación "},{"type":"emphasis","inlineContent":[{"text":"Z","type":"text"}]},{"type":"text","text":" de nuevo en un valor "},{"type":"emphasis","inlineContent":[{"type":"text","text":"x"}]},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"COEFICIENTE DE VARIACIÓN. Una herramienta útil para medir la dispersión es el coeficiente de variación. Compara dos distribuciones y cuantifica cuán dispersa está cada una de ellas. Es simple de calcular: divide la desviación estándar entre la media."}]}],"name":"Note","type":"aside","style":"note"},{"inlineContent":[{"type":"text","text":"Acá te dejo la fórmula junto con el ejemplo comparando dos barrios:"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS13"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS14"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"ZS15"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Como se puede ver acá, el barrio "},{"type":"emphasis","inlineContent":[{"text":"A","type":"text"}]},{"type":"text","text":", aunque más barato que el barrio "},{"type":"emphasis","inlineContent":[{"type":"text","text":"B"}]},{"type":"text","text":", tiene más dispersión y, por lo tanto, más diversidad de precios que el barrio "},{"type":"emphasis","inlineContent":[{"text":"B","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"“Las matemáticas, vistas correctamente, poseen no solo verdad, sino también suprema belleza.”"}],"type":"emphasis"},{"text":" - Bertrand Russell","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Z-Scores"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","variants":[{"paths":["\/documentation\/kreatiodocs\/z-scores"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"ZS8":{"variants":[{"traits":["1x","light"],"svgID":"MJX-33-TEX-I-1D465","url":"\/images\/KreatioDocs\/ZS8.svg"},{"traits":["1x","dark"],"svgID":"MJX-33-TEX-I-1D465","url":"\/images\/KreatioDocs\/ZS8~dark.svg"}],"alt":"x B = 815,000","identifier":"ZS8","type":"image"},"ZS5":{"identifier":"ZS5","type":"image","variants":[{"traits":["1x","light"],"svgID":"MJX-30-TEX-I-1D70E","url":"\/images\/KreatioDocs\/ZS5.svg"},{"traits":["1x","dark"],"svgID":"MJX-30-TEX-I-1D70E","url":"\/images\/KreatioDocs\/ZS5~dark.svg"}],"alt":"\\sigma A = 3,000"},"doc://KreatioDocs/documentation/KreatioDocs/Estadistica-Descriptiva":{"kind":"article","type":"topic","role":"article","title":"Estadística Descriptiva","url":"\/documentation\/kreatiodocs\/estadistica-descriptiva","abstract":[{"type":"text","text":"Comprender los Datos en la Era Moderna."}],"images":[{"identifier":"ED1.png","type":"card"}],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Estadistica-Descriptiva"},"ZS11":{"variants":[{"traits":["1x","light"],"svgID":"MJX-42-TEX-I-1D467","url":"\/images\/KreatioDocs\/ZS11.svg"},{"traits":["1x","dark"],"svgID":"MJX-42-TEX-I-1D467","url":"\/images\/KreatioDocs\/ZS11~dark.svg"}],"alt":"zB = \\frac{815000 - 800000}{10000} = 1.5","identifier":"ZS11","type":"image"},"ZS2":{"identifier":"ZS2","type":"image","variants":[{"traits":["1x","light"],"svgID":"MJX-27-TEX-I-1D467","url":"\/images\/KreatioDocs\/ZS2.svg"},{"traits":["1x","dark"],"svgID":"MJX-27-TEX-I-1D467","url":"\/images\/KreatioDocs\/ZS2~dark.svg"}],"alt":"z = \\frac{x - \\mu}{\\sigma}"},"ZS3":{"variants":[{"traits":["1x","light"],"svgID":"MJX-28-TEX-I-1D707","url":"\/images\/KreatioDocs\/ZS3.svg"},{"traits":["1x","dark"],"svgID":"MJX-28-TEX-I-1D707","url":"\/images\/KreatioDocs\/ZS3~dark.svg"}],"alt":"\\mu A = 140,000","identifier":"ZS3","type":"image"},"ZS6":{"identifier":"ZS6","type":"image","variants":[{"traits":["1x","light"],"svgID":"MJX-31-TEX-I-1D70E","url":"\/images\/KreatioDocs\/ZS6.svg"},{"traits":["1x","dark"],"svgID":"MJX-31-TEX-I-1D70E","url":"\/images\/KreatioDocs\/ZS6~dark.svg"}],"alt":"\\sigma B = 10,000"},"ZS12":{"variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/ZS12.png"}],"alt":null,"identifier":"ZS12","type":"image"},"ZS9":{"identifier":"ZS9","type":"image","variants":[{"traits":["1x","light"],"svgID":"MJX-40-TEX-I-1D467","url":"\/images\/KreatioDo