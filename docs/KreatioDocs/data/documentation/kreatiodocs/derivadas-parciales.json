RC1.png","type":"image"},"doc://KreatioDocs/documentation/KreatioDocs/Derivadas":{"kind":"article","url":"\/documentation\/kreatiodocs\/derivadas","abstract":[{"type":"text","text":"Derivadas en el mundo del cálculo y la programación."}],"type":"topic","role":"article","images":[{"type":"card","identifier":"DER1.png"}],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Derivadas","title":"Derivadas"},"DERP7":{"identifier":"DERP7","alt":"\\lim\\limits_{s \\to 0} \\frac {(x + s)^2 - x^2}{(x+s)-x}","variants":[{"traits":["1x","light"],"svgID":"MJX-65-TEX-N-6C","url":"\/images\/KreatioDocs\/DERP7.svg"},{"traits":["1x","dark"],"svgID":"MJX-65-TEX-N-6C","url":"\/images\/KreatioDocs\/DERP7~dark.svg"}],"type":"image"},"doc://KreatioDocs/documentation/KreatioDocs/Integrales":{"kind":"article","url":"\/documentation\/kreatiodocs\/integrales","type":"topic","abstract":[{"text":"Integración: Desde la Intuición hasta la Aplicación.","type":"text"}],"role":"article","images":[{"type":"card","identifier":"INT1.png"}],"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Integrales","title":"Integrales"},"DERP9":{"variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/DERP9.png"}],"alt":null,"identifier":"DERP9","type":"image"},"doc://KreatioDocs/documentation/KreatioDocs":{"role":"collection","abstract":[],"url":"\/documentation\/kreatiodocs","title":"KreatioDocs","type":"topic","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs","kind":"symbol"},"DERP8":{"identifier":"DERP8","alt":"\\lim\\limits_{s \\to 0} \\frac {(2 + s)^2 - 2^2}{(2+s)-2} = 4","variants":[{"traits":["1x","light"],"svgID":"MJX-66-TEX-N-6C","url":"\/images\/KreatioDocs\/DERP8.svg"},{"traits":["1x","dark"],"svgID":"MJX-66-TEX-N-6C","url":"\/images\/KreatioDocs\/DERP8~dark.svg"}],"type":"image"},"DERP2":{"variants":[{"traits":["1x","light"],"svgID":"MJX-62-TEX-I-1D453","url":"\/images\/KreatioDocs\/DERP2.svg"},{"traits":["1x","dark"],"svgID":"MJX-62-TEX-I-1D453","url":"\/im