ionGroup","images":[{"identifier":"PR_TOG.png","type":"card"}],"abstract":[],"kind":"article"},"doc://KreatioDocs/documentation/KreatioDocs/Uso-Avanzado-de-Tuplas-en-Python":{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Uso-Avanzado-de-Tuplas-en-Python","url":"\/documentation\/kreatiodocs\/uso-avanzado-de-tuplas-en-python","kind":"article","type":"topic","role":"article","images":[{"identifier":"UATP1.png","type":"card"}],"title":"Uso Avanzado de Tuplas en Python","abstract":[]},"doc://KreatioDocs/documentation/KreatioDocs/Secuencias":{"identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Secuencias","url":"\/documentation\/kreatiodocs\/secuencias","kind":"article","type":"topic","role":"article","abstract":[],"images":[{"identifier":"SLTD.png","type":"card"}],"title":"Secuencias: Listas, Tuplas y Diccionarios"},"doc://KreatioDocs/documentation/KreatioDocs/Iniciando-el-Camino-en-Python-Essentials":{"images":[{"identifier":"ICPE.png","type":"card"}],"type":"topic","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs\/Iniciando-el-Camino-en-Python-Essentials","role":"collectionGroup","url":"\/documentation\/kreatiodocs\/iniciando-el-camino-en-python-essentials","abstract":[],"kind":"article","title":"Iniciando el Camino en Python - Essentials"},"DS1":{"identifier":"DS1","type":"image","alt":null,"variants":[{"url":"\/images\/KreatioDocs\/DS1.png","traits":["1x","light"]}]}}}