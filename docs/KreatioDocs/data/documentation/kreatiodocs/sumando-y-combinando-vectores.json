":{"alt":"\\overrightarrow{w} = \\begin{matrix}2 \\\\ -1 \\ \\end{matrix}\\bigr","type":"image","identifier":"SCV4","variants":[{"svgID":"MJX-91-TEX-I-1D464","traits":["1x","light"],"url":"\/images\/KreatioDocs\/SCV4.svg"},{"svgID":"MJX-91-TEX-I-1D464","traits":["1x","dark"],"url":"\/images\/KreatioDocs\/SCV4~dark.svg"}]},"EVM1.png":{"alt":null,"type":"image","identifier":"EVM1.png","variants":[{"url":"\/images\/KreatioDocs\/EVM1.png","traits":["1x","light"]}]},"AL1.png":{"alt":null,"type":"image","identifier":"AL1.png","variants":[{"traits":["1x","light"],"url":"\/images\/KreatioDocs\/AL1.png"}]},"SCV1":{"alt":null,"type":"image","identifier":"SCV1","variants":[{"url":"\/images\/KreatioDocs\/SCV1.png","traits":["1x","light"]}]},"doc://KreatioDocs/documentation/KreatioDocs":{"title":"KreatioDocs","role":"collection","abstract":[],"type":"topic","kind":"symbol","identifier":"doc:\/\/KreatioDocs\/documentation\/KreatioDocs","url":"\/documentation\/kreatiodocs"}}}