o"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Podríamos haber combinado el código en los fragmentos "},{"code":"[10]","type":"codeVoice"},{"type":"text","text":" y "},{"code":"[11]","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","code":["In [13]: another_value = int(input('Ingresa otro entero: '))","Ingresa otro entero: 13","","In [14]: another_value","Out[14]: 13"],"syntax":"python"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Es una buena práctica reducir la cantidad de pasos que el usuario tiene que realizar para completar una tarea, como combinar la entrada y la conversión en una sola línea."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"Las variables ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" y ","type":"text"},{"type":"codeVoice","code":"another_value"},{"text":" ahora contienen enteros. Sumarlos produce un resultado entero (en lugar de concatenarlos):","type":"text"}]},{"type":"codeListing","code":["In [15]: value + another_value","Out[15]: 20"],"syntax":"python"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Manejo de Errores de Conversión"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"Si la cadena pasada a ","type":"text"},{"code":"int","type":"codeVoice"},{"text":" no se puede convertir a un entero, ocurre un ","type":"text"},{"code":"ValueError","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","code":["## In [16]: bad_value = int(input('Ingresa otro entero: '))","Ingresa otro entero: hola","","ValueError                              Rastreo de error (llamada más reciente al final)","<ipython-input-16-cd36e6cf8911> en <module>()","----> 1 bad_value = int(input('Ingresa otro entero: '))","","ValueError: literal no válido para int() con base 10: 'hola'"],"syntax":"python"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Conversi