"In [12]: value","Out[12]: 7"],"type":"codeListing","syntax":"python"},{"inlineContent":[{"inlineContent":[{"text":"Simplificación de la Conversión a Entero","type":"text"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Podríamos haber combinado el código en los fragmentos "},{"type":"codeVoice","code":"[10]"},{"type":"text","text":" y "},{"type":"codeVoice","code":"[11]"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["In [13]: another_value = int(input('Ingresa otro entero: '))","Ingresa otro entero: 13","","In [14]: another_value","Out[14]: 13"],"type":"codeListing","syntax":"python"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Es una buena práctica reducir la cantidad de pasos que el usuario tiene que realizar para completar una tarea, como combinar la entrada y la conversión en una sola línea."}],"type":"paragraph"}],"style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Las variables "},{"type":"codeVoice","code":"value"},{"type":"text","text":" y "},{"type":"codeVoice","code":"another_value"},{"type":"text","text":" ahora contienen enteros. Sumarlos produce un resultado entero (en lugar de concatenarlos):"}]},{"type":"codeListing","syntax":"python","code":["In [15]: value + another_value","Out[15]: 20"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Manejo de Errores de Conversión","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Si la cadena pasada a ","type":"text"},{"code":"int","type":"codeVoice"},{"text":" no se puede convertir a un entero, ocurre un ","type":"text"},{"code":"ValueError","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"python","code":["## In [16]: bad_value = int(input('Ingresa otro entero: '))","Ingresa otro entero: hola","","ValueError                              Rastreo de error (llamada más reciente al final)","<ipython-input-16-cd36e6cf8911> en <modul