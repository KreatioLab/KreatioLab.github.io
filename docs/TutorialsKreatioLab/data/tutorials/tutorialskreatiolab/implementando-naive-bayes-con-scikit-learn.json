e llamada ","type":"text"},{"code":"y_pred_mnb","type":"codeVoice"},{"text":" y calculamos el ","type":"text"},{"inlineContent":[{"text":"accuracy","type":"text"}],"type":"emphasis"},{"text":" con ellos.","type":"text"}],"type":"paragraph"}],"caption":[],"media":null,"type":"step"},{"code":"51-naive-bayes-22.py","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Veamos en la matriz de confusión cómo le fue con las predicciones."}]}],"caption":[],"media":null,"type":"step"},{"code":"51-naive-bayes-23.py","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"El último modelo que investigaremos con este conjunto de datos será el naive bayes bernoulli. Para instanciarlo utilizaremos ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/scikit-learn.org\/stable\/modules\/generated\/sklearn.naive_bayes.BernoulliNB.html"},{"text":" y luego lo entrenaremos con la función ","type":"text"},{"type":"codeVoice","code":"fit()"},{"text":" y los datos de entrenamiento sin escalar.","type":"text"}]}],"caption":[],"media":null,"type":"step"},{"code":"51-naive-bayes-24.py","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Guardamos las predicciones del modelo en una variable llamada "},{"type":"codeVoice","code":"y_pred_bnb"},{"type":"text","text":" y calculamos el "},{"type":"emphasis","inlineContent":[{"type":"text","text":"accuracy"}]},{"type":"text","text":" con ellos."}]}],"caption":[],"media":null,"type":"step"},{"code":"51-naive-bayes-25.py","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Veamos en la matriz de confusión cómo le fue con las predicciones."}]}],"caption":[{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Como podemos ver, ambos modelo performaron mucho peor que el "},{"code":"GaussianNB","type":"codeVoice"},{"type":"text","text":", debido a que la ent