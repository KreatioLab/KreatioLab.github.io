os el escalador en una variable llamada ","type":"text"},{"code":"scaler","type":"codeVoice"},{"text":".","type":"text"}]}],"caption":[]},{"media":null,"code":"51-naive-bayes-15.py","runtimePreview":null,"type":"step","content":[{"inlineContent":[{"text":"A continuación, procederemos a transformar los datos. Primero, utilizaremos la función ","type":"text"},{"code":"fit_transform()","type":"codeVoice"},{"text":" con los datos de ","type":"text"},{"code":"X_train","type":"codeVoice"},{"text":", y con los datos de ","type":"text"},{"code":"X_test","type":"codeVoice"},{"text":" utilizaremos la función ","type":"text"},{"code":"transform()","type":"codeVoice"},{"text":". Esto es así porque el escador debe “aprender” de los datos de entrenamiento y transformarlo, y con los de testeo debe sólo transformarlos.","type":"text"}],"type":"paragraph"}],"caption":[{"inlineContent":[{"type":"text","text":"Ambos resultados se convierten a "},{"type":"codeVoice","code":"DataFrame"},{"type":"text","text":" de pandas y se guardan en variable distintas a las de entrada, por ejemplo "},{"type":"codeVoice","code":"X_train_scaled"},{"type":"text","text":" y "},{"type":"codeVoice","code":"X_test_scaled"},{"type":"text","text":"."}],"type":"paragraph"}]},{"media":null,"code":"51-naive-bayes-16.py","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Con estos nuevos datos de "},{"type":"codeVoice","code":"X"},{"type":"text","text":" de entrenamiento, volvemos a entrenar un modelo naive bayes gaussiano."}]}],"caption":[]},{"media":null,"code":"51-naive-bayes-17.py","runtimePreview":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Guardamos las predicciones del modelo en una variable llamada "},{"code":"y_pred_scaled","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[]},{"media":null,"code":"51-naive-bayes-18.py","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineC